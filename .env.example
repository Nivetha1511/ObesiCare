# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=0
FLASK_APP=api/app.py

# Server Configuration
HOST=0.0.0.0
PORT=5000

# Model Paths
MODEL_PATH=models/obesity_ann.keras
SCALER_PATH=models/scaler.pkl
ENCODER_PATH=models/target_encoder.pkl
FEATURES_PATH=models/feature_columns.pkl

# User Database
USERS_FILE=user_data/users.xlsx

# Security
SECRET_KEY=your_secret_key_here_change_this_in_production

# Database (if using SQL in future)
DATABASE_URL=sqlite:///obesity.db

# API Configuration
MAX_CONTENT_LENGTH=16777216  # 16MB max file upload

# Logging
LOG_LEVEL=INFO
LOG_FILE=app.log
